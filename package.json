{
  "name": "image-cf",
  "version": "1.0.0",
  "description": "Cloudflare Workers AI Image Generator",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute image-cf-db --local --file=./schema.sql",
    "db:migrate": "wrangler d1 execute image-cf-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.78.0"
  }
}
